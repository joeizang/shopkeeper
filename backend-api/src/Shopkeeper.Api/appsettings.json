{
  "ConnectionStrings": {
    "Default": "Data Source=shopkeeper.db"
  },
  "Jwt": {
    "Issuer": "shopkeeper-api",
    "Audience": "shopkeeper-mobile",
    "SigningKey": "change-this-key-in-production-32-chars-minimum",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
