{
  "ConnectionStrings": {
    "Default": "Data Source=shopkeeper.db"
  },
  "Jwt": {
    "Issuer": "shopkeeper-api",
    "Audience": "shopkeeper-mobile",
    "SigningKey": "change-this-key-in-production-32-chars-minimum",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 30
  },
  "GoogleAuth": {
    "AllowedAudiences": [
      "replace-with-google-client-id.apps.googleusercontent.com"
    ]
  },
  "MagicLink": {
    "ExpiryMinutes": 15,
    "MaxRequestsPerMinutePerEmail": 3,
    "AppLinkBaseUrl": "shopkeeper://auth/magic-link"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
